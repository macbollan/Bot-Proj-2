<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>EA Admin Console | ProTrading</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body { background-color: #f1f5f9; font-family: 'Inter', sans-serif; }
        .glass-card { background: white; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); border: 1px solid #e2e8f0; }
        .ea-status-box { background: #0f172a; color: white; border-radius: 12px; padding: 20px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); }
        .text-accent { color: #38bdf8; }
        .table-hover tbody tr:hover { background-color: #f8fafc; }
    </style>
</head>
<body>
    <nav class="navbar navbar-dark bg-dark mb-4 py-3 shadow">
        <div class="container-fluid px-4">
            <a class="navbar-brand fw-bold" href="/admin"><i class="bi bi-cpu-fill text-primary me-2"></i>Master EA Control Room</a>
            <a href="/logout" class="btn btn-sm btn-danger"><i class="bi bi-power"></i> System Logout</a>
        </div>
    </nav>

    <div class="container-fluid px-4">
        <div class="row g-4 mb-4">
            <div class="col-xl-4 col-lg-5">
                <div class="ea-status-box h-100">
                    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-secondary pb-3">
                        <h5 class="fw-bold m-0"><i class="bi bi-activity text-accent me-2"></i>Live Master Status</h5>
                        <span class="badge bg-success shadow-sm"><i class="bi bi-broadcast"></i> Receiving</span>
                    </div>

                    <div class="row mb-3">
                        <div class="col-6">
                            <small class="text-secondary text-uppercase fw-bold">Active Pair</small>
                            <h4 id="ea-symbol" class="mt-1 fw-bold">--</h4>
                        </div>
                        <div class="col-6">
                            <small class="text-secondary text-uppercase fw-bold">Live Price</small>
                            <h4 id="ea-price" class="mt-1 text-accent">0.00</h4>
                        </div>
                    </div>
                    
                    <div class="row mb-4">
                        <div class="col-6">
                            <small class="text-secondary text-uppercase fw-bold">Market Trend</small>
                            <div id="ea-trend" class="mt-1 fs-5 fw-semibold text-warning">--</div>
                        </div>
                        <div class="col-6">
                            <small class="text-secondary text-uppercase fw-bold">Open Trades</small>
                            <div id="ea-trades" class="mt-1 fs-5 fw-bold text-white">0</div>
                        </div>
                    </div>

                    <small class="text-secondary text-uppercase fw-bold d-block mb-2">Live Equity Curve (Master Account)</small>
                    <canvas id="equityChart" height="120"></canvas>
                </div>
            </div>

            <div class="col-xl-8 col-lg-7">
                <div class="glass-card p-4 h-100">
                    <h5 class="fw-bold mb-4"><i class="bi bi-people-fill text-primary me-2"></i>Client Licenses & Subscriptions</h5>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light text-secondary small text-uppercase">
                                <tr>
                                    <th>Client</th>
                                    <th>Status</th>
                                    <th>License Key</th>
                                    <th>MT5 Lock</th>
                                    <th>Expires On</th>
                                    <th class="text-end">Controls</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% users.forEach(client => { %>
                                    <tr class="<%= client.isSuspended ? 'table-danger' : '' %>">
                                        <td class="fw-bold"><%= client.username %></td>
                                        <td>
                                            <% if(client.isSuspended) { %> <span class="badge bg-danger">Suspended</span>
                                            <% } else if(new Date() > new Date(client.licenseExpiry)) { %> <span class="badge bg-warning text-dark">Expired</span>
                                            <% } else if(client.licenseKey) { %> <span class="badge bg-success">Active</span>
                                            <% } else { %> <span class="badge bg-secondary">None</span> <% } %>
                                        </td>
                                        <td><code class="text-primary fw-bold bg-light px-2 py-1 rounded"><%= client.licenseKey || '---' %></code></td>
                                        <td class="small text-muted"><%= client.mt5AccountNumber || 'Pending Login' %></td>
                                        <td class="small fw-semibold <%= new Date() > new Date(client.licenseExpiry) ? 'text-danger' : 'text-success' %>">
                                            <%= client.licenseExpiry ? new Date(client.licenseExpiry).toLocaleDateString() : '-' %>
                                        </td>
                                        <td class="text-end">
                                            <div class="d-flex justify-content-end gap-2">
                                                <form action="/admin/generate-license/<%= client._id %>" method="POST" class="d-flex shadow-sm rounded">
                                                    <div class="input-group input-group-sm" style="width: 140px;">
                                                        <input type="number" name="durationDays" class="form-control text-center" value="30" required title="Duration in Days">
                                                        <span class="input-group-text bg-light text-muted">Days</span>
                                                        <button type="submit" class="btn btn-primary"><i class="bi bi-key-fill"></i></button>
                                                    </div>
                                                </form>

                                                <% if(client.licenseKey) { %>
                                                    <form action="/admin/suspend-license/<%= client._id %>" method="POST">
                                                        <button type="submit" class="btn btn-sm shadow-sm <%= client.isSuspended ? 'btn-success' : 'btn-danger' %>">
                                                            <i class="bi <%= client.isSuspended ? 'bi-play-fill' : 'bi-pause-fill' %>"></i>
                                                        </button>
                                                    </form>
                                                <% } %>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        const ctx = document.getElementById('equityChart').getContext('2d');
        const equityChart = new Chart(ctx, {
            type: 'line',
            data: { labels: Array(50).fill(''), datasets: [{ data: [], borderColor: '#38bdf8', backgroundColor: 'rgba(56, 189, 248, 0.1)', borderWidth: 2, fill: true, pointRadius: 0 }] },
            options: { scales: { x: { display: false }, y: { display: true, grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#94a3b8' } } }, plugins: { legend: { display: false } }, animation: { duration: 0 } }
        });

        async function fetchAdminEAData() {
            try {
                const res = await fetch('/api/public/ea-state');
                const data = await res.json();
                document.getElementById('ea-symbol').innerText = data.symbol;
                document.getElementById('ea-price').innerText = data.price ? parseFloat(data.price).toFixed(4) : "0.00";
                document.getElementById('ea-trend').innerText = data.trend;
                document.getElementById('ea-trades').innerText = data.openTrades || 0;
                
                if(data.equityHistory && data.equityHistory.length > 0) {
                    equityChart.data.datasets[0].data = data.equityHistory;
                    equityChart.update();
                }
            } catch (e) {}
        }
        setInterval(fetchAdminEAData, 2000);
    </script>
</body>
</html>