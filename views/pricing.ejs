<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>Choose Your Trading Level | D.E.T System</title>
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@100;300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Bootstrap core CSS -->
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background-color: #1a1818;
            font-family: 'Poppins', sans-serif;
            color: #ffffff;
            padding-top: 100px; /* Space for fixed header */
            margin: 0;
        }

        /* =========================================
           CUSTOM NEUTRAL NAVBAR
        ========================================= */
        .custom-navbar {
            background-color: #322C2C;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            z-index: 1000;
            box-shadow: 0 2px 15px rgba(0,0,0,0.5);
            padding: 18px 0;
        }
        .nav-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }
        .text-logo {
            color: #B0BF96;
            font-size: 26px;
            font-weight: 800;
            text-decoration: none;
            letter-spacing: 1.5px;
            text-transform: uppercase;
        }
        .text-logo span {
            color: #ffffff;
            font-weight: 300;
        }
        .text-logo:hover {
            color: #ffffff;
        }
        .nav-menu {
            display: flex;
            list-style: none;
            margin: 0;
            padding: 0;
            gap: 30px;
        }
        .nav-menu li a {
            color: #ffffff;
            text-decoration: none;
            font-size: 15px;
            font-weight: 500;
            transition: color 0.3s;
        }
        .nav-menu li a:hover, .nav-menu li a.active {
            color: #B0BF96;
        }
        .mobile-toggle {
            display: none;
            color: #ffffff;
            font-size: 28px;
            cursor: pointer;
            user-select: none;
        }

        /* Mobile Menu Responsiveness */
        @media (max-width: 991px) {
            .nav-menu {
                display: none;
                flex-direction: column;
                position: absolute;
                top: 100%;
                left: 0;
                width: 100%;
                background-color: #322C2C;
                padding: 20px 0;
                box-shadow: 0 10px 15px rgba(0,0,0,0.5);
                text-align: center;
            }
            .nav-menu.active {
                display: flex;
            }
            .nav-menu li {
                padding: 10px 0;
            }
            .mobile-toggle {
                display: block;
            }
        }

        /* =========================================
           PAGE STYLES & CARDS
        ========================================= */
        .page-heading {
            text-align: center;
            padding: 40px 0;
        }
        .page-heading h2 {
            color: #B0BF96;
            font-size: 36px;
            font-weight: 700;
            margin-bottom: 10px;
        }
        .page-heading p {
            color: #aaa;
            font-size: 16px;
        }
        .step-indicator {
            text-transform: uppercase;
            letter-spacing: 2px;
            font-size: 13px;
            color: #B0BF96;
            font-weight: 600;
            display: block;
            margin-bottom: 15px;
        }

        .pricing-grid {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 30px;
            padding-bottom: 80px;
        }
        .tier-card {
            background: #322C2C;
            border: 1px solid rgba(176, 191, 150, 0.2);
            border-radius: 12px;
            padding: 35px 25px;
            width: 100%;
            max-width: 350px;
            text-align: center;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }
        .tier-card:hover {
            border-color: #B0BF96;
            transform: translateY(-8px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.4);
        }
        .tier-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 4px;
            background: linear-gradient(90deg, #B0BF96, #728352);
            opacity: 0;
            transition: opacity 0.3s;
        }
        .tier-card:hover::before {
            opacity: 1;
        }

        .tier-name {
            color: #ffffff;
            font-size: 22px;
            font-weight: 600;
            margin-bottom: 15px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .tier-price {
            color: #B0BF96;
            font-size: 38px;
            font-weight: 700;
            margin-bottom: 5px;
            line-height: 1;
        }
        .tier-rate {
            color: #888;
            font-size: 14px;
            margin-bottom: 25px;
        }
        
        .tier-details {
            background: rgba(0,0,0,0.2);
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 25px;
            text-align: left;
        }
        .tier-details span {
            display: block;
            font-size: 13px;
            color: #aaa;
            margin-bottom: 5px;
        }
        .tier-details strong {
            color: #fff;
            font-size: 15px;
        }

        .agreement-section {
            text-align: left;
            margin-top: auto;
            margin-bottom: 20px;
            padding-top: 20px;
            border-top: 1px solid rgba(255,255,255,0.05);
        }
        .form-check {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            padding-left: 0;
        }
        .form-check-input {
            margin-top: 4px;
            background-color: transparent;
            border: 1px solid #B0BF96;
            width: 18px;
            height: 18px;
            cursor: pointer;
        }
        .form-check-input:checked {
            background-color: #B0BF96;
            border-color: #B0BF96;
        }
        .form-check-label {
            font-size: 12px;
            color: #999;
            line-height: 1.5;
            cursor: pointer;
        }
        .form-check-label strong {
            color: #ccc;
        }

        .btn-secure {
            background: transparent;
            color: #B0BF96;
            border: 1px solid #B0BF96;
            border-radius: 6px;
            padding: 12px 20px;
            font-weight: 600;
            font-size: 14px;
            width: 100%;
            transition: all 0.3s;
            cursor: pointer;
        }
        .btn-secure:disabled {
            border-color: #444;
            color: #555;
            cursor: not-allowed;
            background: rgba(0,0,0,0.2);
        }
        .btn-secure:not(:disabled):hover {
            background: #B0BF96;
            color: #322C2C;
        }

        .nav-menu {
            display: flex;
            list-style: none;
            margin: 0;
            padding: 0;
            gap: 30px;
            align-items: center;
        }
        .nav-menu li a {
            color: #ffffff;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: color 0.3s;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .nav-menu li a:hover, .nav-menu li a.active {
            color: #B0BF96;
        }
        
        /* Highlighted Get Started Button */
        .nav-btn {
            background: #B0BF96;
            color: #322C2C !important;
            padding: 10px 20px;
            border-radius: 6px;
            font-weight: 700 !important;
            transition: all 0.3s ease;
        }
        .nav-btn:hover {
            background: #96a67c;
            transform: translateY(-2px);
        }
        .mobile-toggle {
            display: none;
            color: #ffffff;
            font-size: 28px;
            cursor: pointer;
            user-select: none;
        }

        /* Mobile Menu */
        @media (max-width: 991px) {
            .nav-menu {
                display: none;
                flex-direction: column;
                position: absolute;
                top: 100%;
                left: 0;
                width: 100%;
                background-color: #322C2C;
                padding: 20px 0;
                box-shadow: 0 10px 15px rgba(0,0,0,0.5);
                text-align: center;
            }
            .nav-menu.active {
                display: flex;
            }
            .nav-menu li {
                padding: 10px 0;
            }
            .mobile-toggle {
                display: block;
            }
        }
    </style>
</head>
<body>

    <!-- ***** Custom Navbar Start ***** -->

    <!-- ***** Custom Navbar Start ***** -->
    <header class="custom-navbar">
        <div class="nav-container">
            <a href="/" class="text-logo">D.E.T <span>SYSTEM</span></a>
            <div class="mobile-toggle" id="mobile-toggle">☰</div>
            <ul class="nav-menu" id="nav-menu">
                <li><a href="/">Home</a></li>
                <li><a href="/pricing">Trading Levels</a></li>
                <li><a href="/login">Client Access</a></li>
                <li><a href="/pricing" class="nav-btn">Get Started</a></li>
            </ul>
        </div>
    </header>
    <!-- ***** Custom Navbar End ***** -->
    <!-- ***** Custom Navbar End ***** -->

    <!-- ***** Main Content Start ***** -->
    <div class="container">
        <div class="page-heading">
            <span class="step-indicator">Step 1 of 4</span>
            <h2>Choose Your Trading Level</h2>
            <p>Select the D.E.T tier that aligns with your custodial account float size.</p>
        </div>

        <% if(error && error.length > 0) { %> 
            <div class="alert alert-danger" style="background: rgba(255,0,0,0.1); border-color: red; color: #ff6b6b; text-align: center; max-width: 600px; margin: 0 auto 30px;">
                <%= error %>
            </div> 
        <% } %>

        <div class="pricing-grid">
            <% tiers.forEach(function(tier) { %>
                <div class="tier-card">
                    <h3 class="tier-name"><%= tier.name %></h3>
                    <div class="tier-price"><%= tier.amount %></div>
                    <div class="tier-rate"><%= tier.rate %></div>
                    
                    <div class="tier-details">
                        <span>Approved Trading Float</span>
                        <strong><%= tier.range %></strong>
                    </div>
                    
                    <form action="/checkout/initialize" method="POST" class="checkout-form d-flex flex-column" style="flex-grow: 1;">
                        <input type="hidden" name="selectedTier" value="<%= tier.name %>">
                        
                        <div class="agreement-section">
                            <div class="form-check">
                                <input class="form-check-input terms-checkbox" type="checkbox" name="termsAgreed" required id="terms-<%= tier.name %>">
                                <label class="form-check-label" for="terms-<%= tier.name %>">
                                    <strong>Confirm Your D.E.T Agreement:</strong> I understand and agree to continue with D.E.T. I have read the Risk Disclosure.
                                </label>
                            </div>
                        </div>

                        <% if(tier.name === "Amber") { %>
                            <button type="button" class="btn-secure" disabled style="border-color: #444; color: #555;">Not Available</button>
                        <% } else { %>
                            <button type="submit" class="btn-secure submit-btn" disabled>
                                Continue to Secure Payment
                            </button>
                        <% } %>
                    </form>
                </div>
            <% }); %>
        </div>
    </div>
    <!-- ***** Main Content End ***** -->

    <!-- ***** Footer Start ***** -->
    <footer role="contentinfo" style="background: #322C2C; padding: 30px 0; border-top: 1px solid rgba(255,255,255,0.05); text-align: center; margin-top: auto;">
        <div class="container">
            <p style="color: #888; font-size: 14px; margin: 0;">
                Copyright © 2026 D.E.T System. All Rights Reserved.<br>
            </p>
        </div>
    </footer>
    <!-- ***** Footer End ***** -->

    <!-- Scripts -->
    <script>
        // Mobile Menu Toggle Logic
        document.getElementById('mobile-toggle').addEventListener('click', function() {
            document.getElementById('nav-menu').classList.toggle('active');
        });

        // Terms & Conditions Checkbox Logic
        document.querySelectorAll('.checkout-form').forEach(form => {
            const checkbox = form.querySelector('.terms-checkbox');
            const submitBtn = form.querySelector('.submit-btn');
            
            if(checkbox && submitBtn) {
                checkbox.addEventListener('change', function() {
                    submitBtn.disabled = !this.checked;
                });
            }
        });
    </script>
</body>
</html>